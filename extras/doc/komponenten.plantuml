@startuml Komponenten

left to right direction

actor RESTClient
actor GraphQLClient

node "Hono" {
  [Hono App]
  [Middleware \nrolesAllowed()]
  [Router / Handler]

  [Yoga Server]
  [Resolver / Handler]

  [BuchService]

  [PrismaClient]

  [MailService]
}


cloud {
    [Prisma]
}

cloud {
    [jose \nissuer]
}

cloud {
    [nodemailer]
}

database "DB buch" {
    [Tabelle \nbuch]
    [Tabelle \ntitel]
    [Tabelle \nabbildung]
}

node {
    [Keycloak]
}

node {
    [Mailserver]
}

RESTClient ~~> [Hono App]
[Hono App] ..> [Middleware \nrolesAllowed()]
[MailService] ~[hidden]~> [jose \nissuer]
[Middleware \nrolesAllowed()] ~~> [jose \nissuer]
[Middleware \nrolesAllowed()] ..> [Router / Handler]
[Router / Handler] ..> [BuchService]

GraphQLClient ~~> [Hono App]
[Hono App] ..> [Yoga Server]
[Yoga Server] ..> [Resolver / Handler]
[Resolver / Handler] ..> [BuchService]
[Resolver / Handler] ~~> [jose \nissuer]

[BuchService] ..> [PrismaClient]

[PrismaClient] ~~> [Prisma]
[Prisma] ~~> [Tabelle \nbuch]
[Prisma] ~~> [Tabelle \ntitel]
[Prisma] ~~> [Tabelle \nabbildung]

[jose \nissuer] ~~> [Keycloak]

[BuchService] ..> [MailService]
[MailService] ~~> [nodemailer]
[nodemailer] ~~> [Mailserver]

footer (c) Jürgen Zimmermann

@enduml
